---
import type { GhostAuthor } from "@healthpulse/ghost-client";
import { getAuthorUrl } from "@/lib/utils";

interface Props {
	author: GhostAuthor;
	showBio?: boolean;
	size?: "sm" | "lg";
}

const { author, showBio = false, size = "sm" } = Astro.props;
const url = getAuthorUrl(author.slug);
const avatarSize = size === "lg" ? "w-14 h-14" : "w-10 h-10";
---

<div class="flex items-start gap-3">
	<a href={url} class:list={["rounded-full bg-teal-100 text-teal-700 flex items-center justify-center font-bold flex-shrink-0", avatarSize]}>
		{author.profile_image ? (
			<img
				src={author.profile_image}
				alt={author.name}
				class:list={["rounded-full object-cover", avatarSize]}
				loading="lazy"
			/>
		) : (
			<span class={size === "lg" ? "text-xl" : "text-sm"}>
				{author.name.split(" ").map((n) => n[0]).join("").slice(0, 2)}
			</span>
		)}
	</a>
	<div>
		<a href={url} class="font-semibold text-gray-900 hover:text-teal-700 transition-colors">
			{author.name}
		</a>
		{showBio && author.bio && (
			<p class="mt-1 text-sm text-gray-600 leading-relaxed line-clamp-2">{author.bio}</p>
		)}
	</div>
</div>

---
import { getCategoryBySlug } from "@/data/categories";

interface Props {
	slug: string;
	size?: "sm" | "md";
	linked?: boolean;
}

const { slug, size = "sm", linked = true } = Astro.props;
const category = getCategoryBySlug(slug);
const label = category?.name.split(" & ")[0] ?? slug;

const colorMap: Record<string, string> = {
	"cat-leadership": "bg-blue-100 text-blue-800",
	"cat-patient": "bg-emerald-100 text-emerald-800",
	"cat-clinical": "bg-violet-100 text-violet-800",
	"cat-operations": "bg-amber-100 text-amber-800",
	"cat-technology": "bg-sky-100 text-sky-800",
	"cat-regulatory": "bg-red-100 text-red-800",
};

const colorClass = colorMap[category?.color ?? ""] ?? "bg-gray-100 text-gray-700";
const sizeClass = size === "sm" ? "px-2 py-0.5 text-xs" : "px-3 py-1 text-sm";
---

{linked ? (
	<a
		href={`/${slug}/`}
		class:list={["inline-block font-medium rounded-full transition-opacity hover:opacity-80", colorClass, sizeClass]}
	>
		{label}
	</a>
) : (
	<span class:list={["inline-block font-medium rounded-full", colorClass, sizeClass]}>
		{label}
	</span>
)}

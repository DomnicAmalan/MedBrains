---
interface Props {
	variant?: "banner" | "sidebar";
}

const { variant = "banner" } = Astro.props;
---

{variant === "sidebar" ? (
	<div class="bg-gradient-to-br from-gray-900 to-gray-800 rounded-lg p-5 text-white">
		<p class="text-xs font-medium text-teal-400 uppercase tracking-wider">From the makers of HealthPulse</p>
		<h3 class="mt-2 text-base font-bold">MedBrains HMS</h3>
		<p class="mt-2 text-sm text-gray-300 leading-relaxed">
			Complete Hospital Management System — 67+ modules, built for Indian hospitals.
		</p>
		<a
			href="https://medbrains.in?utm_source=healthpulse&utm_medium=sidebar_cta"
			target="_blank"
			rel="noopener"
			class="mt-4 inline-block w-full text-center px-4 py-2 bg-teal-600 hover:bg-teal-500 text-white text-sm font-medium rounded-md transition-colors"
		>
			Request a Demo
		</a>
	</div>
) : (
	<div class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 rounded-xl p-8 my-10 flex flex-col md:flex-row items-center gap-6">
		<div class="flex-1">
			<p class="text-xs font-medium text-teal-400 uppercase tracking-wider">From the makers of HealthPulse</p>
			<h3 class="mt-2 text-xl font-bold text-white">Run your hospital on MedBrains</h3>
			<p class="mt-2 text-gray-300 leading-relaxed">
				67+ integrated modules for clinical, administrative, and financial workflows.
				Built specifically for Indian hospitals. NABH-ready out of the box.
			</p>
		</div>
		<a
			href="https://medbrains.in?utm_source=healthpulse&utm_medium=article_banner"
			target="_blank"
			rel="noopener"
			class="flex-shrink-0 px-6 py-3 bg-teal-600 hover:bg-teal-500 text-white font-semibold rounded-lg transition-colors"
		>
			Request a Demo
		</a>
	</div>
)}

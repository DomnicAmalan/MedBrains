---
import { CATEGORIES } from "@/data/categories";
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-200">
	<a href="#main-content" class="skip-to-content">Skip to content</a>

	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<!-- Top bar -->
		<div class="flex items-center justify-between h-16">
			<!-- Logo -->
			<a href="/" class="flex items-center gap-2 text-teal-700 hover:text-teal-800 transition-colors">
				<img src="/favicon.svg" alt="" width="28" height="28" />
				<span class="text-xl font-bold tracking-tight">HealthPulse</span>
			</a>

			<!-- Desktop nav -->
			<nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
				{CATEGORIES.map((cat) => (
					<a
						href={`/${cat.slug}/`}
						class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-teal-700 hover:bg-teal-50 rounded-md transition-colors"
					>
						{cat.name.split(" & ")[0]}
					</a>
				))}
			</nav>

			<!-- Right side -->
			<div class="flex items-center gap-3">
				<a
					href="/search/"
					class="p-2 text-gray-500 hover:text-teal-700 transition-colors"
					aria-label="Search"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
					</svg>
				</a>

				<!-- Mobile menu button -->
				<button
					id="mobile-menu-btn"
					class="lg:hidden p-2 text-gray-500 hover:text-teal-700 transition-colors"
					aria-label="Open menu"
					aria-expanded="false"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
					</svg>
				</button>
			</div>
		</div>
	</div>

	<!-- Mobile menu -->
	<nav
		id="mobile-menu"
		class="hidden lg:hidden border-t border-gray-200 bg-white"
		aria-label="Mobile navigation"
	>
		<div class="px-4 py-3 space-y-1">
			{CATEGORIES.map((cat) => (
				<a
					href={`/${cat.slug}/`}
					class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-teal-700 hover:bg-teal-50 rounded-md transition-colors"
				>
					{cat.name}
				</a>
			))}
			<hr class="my-2 border-gray-100" />
			<a
				href="/about/"
				class="block px-3 py-2 text-sm text-gray-500 hover:text-teal-700 rounded-md"
			>
				About
			</a>
			<a
				href="/editorial-standards/"
				class="block px-3 py-2 text-sm text-gray-500 hover:text-teal-700 rounded-md"
			>
				Editorial Standards
			</a>
		</div>
	</nav>
</header>

<script>
	const btn = document.getElementById("mobile-menu-btn");
	const menu = document.getElementById("mobile-menu");
	btn?.addEventListener("click", () => {
		const expanded = btn.getAttribute("aria-expanded") === "true";
		btn.setAttribute("aria-expanded", String(!expanded));
		menu?.classList.toggle("hidden");
	});
</script>

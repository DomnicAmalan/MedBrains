---
import type { GhostPost } from "@healthpulse/ghost-client";
import { formatDate, formatReadingTime, getPostUrl, truncate } from "@/lib/utils";
import CategoryBadge from "./CategoryBadge.astro";

interface Props {
	post: GhostPost;
}

const { post } = Astro.props;
const url = getPostUrl(post);
const excerpt = post.custom_excerpt ?? post.excerpt ?? "";
---

<section class="relative bg-gray-900 rounded-2xl overflow-hidden mb-10">
	{post.feature_image && (
		<img
			src={post.feature_image}
			alt={post.feature_image_alt ?? post.title}
			class="absolute inset-0 w-full h-full object-cover opacity-40"
			loading="eager"
		/>
	)}
	<div class="relative z-10 p-8 md:p-12 lg:p-16 max-w-3xl">
		{post.primary_tag && <CategoryBadge slug={post.primary_tag.slug} size="md" />}
		<a href={url} class="block group">
			<h1 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight group-hover:text-teal-300 transition-colors">
				{post.title}
			</h1>
		</a>
		<p class="mt-4 text-lg text-gray-200 leading-relaxed max-w-2xl">
			{truncate(excerpt, 200)}
		</p>
		<div class="mt-6 flex items-center gap-4 text-sm text-gray-300">
			<span class="font-medium">{post.primary_author.name}</span>
			<span>&middot;</span>
			<time datetime={post.published_at}>{formatDate(post.published_at)}</time>
			<span>&middot;</span>
			<span>{formatReadingTime(post.reading_time)}</span>
		</div>
	</div>
</section>

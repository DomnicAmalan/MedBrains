---
interface Props {
	variant?: "global" | "patient" | "drug";
}

const { variant = "global" } = Astro.props;

const disclaimers: Record<string, { title: string; text: string }> = {
	global: {
		title: "Medical Disclaimer",
		text: "The information on this website is for educational and informational purposes only and is not a substitute for professional medical advice, diagnosis, or treatment. Always seek the advice of your physician or other qualified health provider.",
	},
	patient: {
		title: "Important Health Information",
		text: "This article contains health information intended for patient education. It has been reviewed by a medical professional, but it is not a substitute for your doctor's advice. Your individual health situation is unique — always consult your healthcare provider before making any changes to your treatment.",
	},
	drug: {
		title: "Medication Information Notice",
		text: "Drug information presented here is for educational reference only. Do not start, stop, or change the dosage of any medication without consulting your doctor or pharmacist. Medication effects may vary based on individual factors.",
	},
};

const disclaimer = disclaimers[variant];
---

<aside class="bg-amber-50 border-l-4 border-amber-400 p-4 rounded-r-lg my-6" role="note" aria-label="Medical disclaimer">
	<p class="text-sm text-amber-900">
		<strong>{disclaimer.title}:</strong> {disclaimer.text}
	</p>
</aside>

---
interface Props {
	reviewerName: string;
	reviewDate: string;
	credentials?: string;
}

const { reviewerName, reviewDate, credentials } = Astro.props;
const formattedDate = new Date(reviewDate).toLocaleDateString("en-IN", {
	year: "numeric",
	month: "long",
	day: "numeric",
});
---

<div class="flex items-center gap-2 px-4 py-3 bg-emerald-50 border border-emerald-200 rounded-lg text-sm">
	<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-600 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
		<path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
	</svg>
	<div>
		<span class="text-emerald-800 font-medium">Medically reviewed</span>
		<span class="text-emerald-700">
			by {reviewerName}{credentials ? `, ${credentials}` : ""}
		</span>
		<span class="text-emerald-600"> &mdash; {formattedDate}</span>
	</div>
</div>

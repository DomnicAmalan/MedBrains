---
interface Props {
	variant?: "inline" | "sidebar";
}

const { variant = "inline" } = Astro.props;
---

{variant === "sidebar" ? (
	<div class="bg-teal-50 border border-teal-200 rounded-lg p-5">
		<h3 class="text-base font-bold text-teal-900">Healthcare Insights Weekly</h3>
		<p class="mt-2 text-sm text-teal-700">
			Curated healthcare news and analysis, delivered every Thursday.
		</p>
		<form class="mt-4 space-y-2" action="#" method="POST">
			<input
				type="email"
				name="email"
				placeholder="your@email.com"
				required
				class="w-full px-3 py-2 border border-teal-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
			/>
			<button
				type="submit"
				class="w-full px-4 py-2 bg-teal-700 hover:bg-teal-600 text-white text-sm font-medium rounded-md transition-colors"
			>
				Subscribe — it's free
			</button>
		</form>
		<p class="mt-2 text-xs text-teal-600">No spam. Unsubscribe anytime.</p>
	</div>
) : (
	<div class="bg-gradient-to-r from-teal-700 to-teal-600 rounded-xl p-8 text-center my-10">
		<h3 class="text-xl font-bold text-white">Get smarter about healthcare</h3>
		<p class="mt-2 text-teal-100 max-w-md mx-auto">
			Join healthcare professionals who read HealthPulse weekly for insights that matter.
		</p>
		<form class="mt-6 flex flex-col sm:flex-row gap-3 max-w-md mx-auto" action="#" method="POST">
			<input
				type="email"
				name="email"
				placeholder="your@email.com"
				required
				class="flex-1 px-4 py-3 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-300"
			/>
			<button
				type="submit"
				class="px-6 py-3 bg-white text-teal-700 text-sm font-bold rounded-lg hover:bg-teal-50 transition-colors"
			>
				Subscribe
			</button>
		</form>
		<p class="mt-3 text-xs text-teal-200">Free weekly newsletter. No spam, unsubscribe anytime.</p>
	</div>
)}

---
import type { GhostPost } from "@healthpulse/ghost-client";
import { formatDate, getPostUrl } from "@/lib/utils";
import CategoryBadge from "./CategoryBadge.astro";

interface Props {
	post: GhostPost;
}

const { post } = Astro.props;
const url = getPostUrl(post);
---

<article class="group">
	<a href={url} class="flex items-start gap-4 py-4 border-b border-gray-100 hover:bg-gray-50 -mx-2 px-2 rounded-lg transition-colors">
		<div class="flex-1 min-w-0">
			{post.primary_tag && <CategoryBadge slug={post.primary_tag.slug} size="sm" />}
			<h3 class="mt-1 text-sm font-semibold text-gray-900 group-hover:text-teal-700 transition-colors leading-snug line-clamp-2">
				{post.title}
			</h3>
			<div class="mt-1 flex items-center gap-2 text-xs text-gray-500">
				<time datetime={post.published_at}>{formatDate(post.published_at)}</time>
			</div>
		</div>
	</a>
</article>

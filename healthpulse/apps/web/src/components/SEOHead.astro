---
import type { SEOMetadata } from "@healthpulse/types";
import { buildTitle } from "@/lib/seo";

interface Props {
	seo: Partial<SEOMetadata>;
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { seo, jsonLd } = Astro.props;
const title = buildTitle(seo.title);
const description = seo.description ?? "India's leading healthcare publishing platform.";
const canonicalUrl = seo.canonicalUrl ?? Astro.url.pathname;
const ogImage = seo.ogImage;
const ogType = seo.ogType ?? "website";
const twitterCard = seo.twitterCard ?? "summary_large_image";
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={new URL(canonicalUrl, Astro.site).toString()} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={new URL(canonicalUrl, Astro.site).toString()} />
<meta property="og:site_name" content="HealthPulse" />
{ogImage && <meta property="og:image" content={ogImage} />}
{seo.publishedTime && <meta property="article:published_time" content={seo.publishedTime} />}
{seo.modifiedTime && <meta property="article:modified_time" content={seo.modifiedTime} />}
{seo.author && <meta property="article:author" content={seo.author} />}
{seo.section && <meta property="article:section" content={seo.section} />}
{seo.tags?.map((tag) => <meta property="article:tag" content={tag} />)}

<!-- Twitter Card -->
<meta name="twitter:card" content={twitterCard} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

<!-- Robots -->
{seo.noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- JSON-LD Structured Data -->
{jsonLd && (
	Array.isArray(jsonLd)
		? jsonLd.map((schema) => (
			<script type="application/ld+json" set:html={JSON.stringify(schema)} />
		))
		: <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}

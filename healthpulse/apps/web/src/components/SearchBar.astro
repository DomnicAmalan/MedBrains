---
interface Props {
	variant?: "header" | "page";
}

const { variant = "page" } = Astro.props;
---

{variant === "page" ? (
	<div id="search-container" class="max-w-2xl mx-auto">
		<div class="relative">
			<svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
			</svg>
			<input
				type="search"
				id="search-input"
				placeholder="Search articles, topics, authors..."
				class="w-full pl-12 pr-4 py-4 text-lg border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
				autofocus
			/>
		</div>
		<div id="search-results" class="mt-6"></div>
	</div>
) : (
	<a href="/search/" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-500 hover:text-teal-700 border border-gray-200 rounded-lg hover:border-teal-300 transition-colors">
		<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
			<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
		</svg>
		<span>Search...</span>
	</a>
)}

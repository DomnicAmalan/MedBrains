---
interface Props {
	sources: Array<{ title: string; url?: string; author?: string; date?: string }>;
}

const { sources } = Astro.props;
---

{sources.length > 0 && (
	<section class="mt-10 pt-8 border-t border-gray-200">
		<h2 class="text-lg font-bold text-gray-900 mb-4">Sources & References</h2>
		<ol class="list-decimal list-inside space-y-2">
			{sources.map((source) => (
				<li class="text-sm text-gray-600">
					{source.url ? (
						<a href={source.url} target="_blank" rel="noopener noreferrer" class="text-teal-700 hover:underline">
							{source.title}
						</a>
					) : (
						<span>{source.title}</span>
					)}
					{source.author && <span> &mdash; {source.author}</span>}
					{source.date && <span> ({source.date})</span>}
				</li>
			))}
		</ol>
	</section>
)}

---
interface Props {
	headings: Array<{ id: string; text: string; level: number }>;
}

const { headings } = Astro.props;
---

{headings.length > 0 && (
	<nav class="bg-gray-50 border border-gray-200 rounded-lg p-5 my-6" aria-label="Table of contents">
		<h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-3">In this article</h2>
		<ul class="space-y-2">
			{headings.map((h) => (
				<li class:list={[h.level === 3 ? "ml-4" : ""]}>
					<a
						href={`#${h.id}`}
						class="text-sm text-gray-600 hover:text-teal-700 transition-colors"
					>
						{h.text}
					</a>
				</li>
			))}
		</ul>
	</nav>
)}

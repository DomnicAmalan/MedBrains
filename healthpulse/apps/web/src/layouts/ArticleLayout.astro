---
import type { GhostPost } from "@healthpulse/ghost-client";
import { buildArticleSchema, buildBreadcrumbSchema } from "@/lib/seo";
import { addHeadingIds, extractHeadings, formatDate, formatReadingTime, getPostCategory, getPostUrl } from "@/lib/utils";
import { getCategoryBySlug } from "@/data/categories";
import BaseLayout from "./BaseLayout.astro";
import AuthorByline from "@/components/AuthorByline.astro";
import CategoryBadge from "@/components/CategoryBadge.astro";
import MedicalDisclaimer from "@/components/MedicalDisclaimer.astro";
import MedicalReviewBadge from "@/components/MedicalReviewBadge.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import ShareButtons from "@/components/ShareButtons.astro";
import NewsletterSignup from "@/components/NewsletterSignup.astro";
import HMSLeadCTA from "@/components/HMSLeadCTA.astro";

interface Props {
	post: GhostPost;
}

const { post } = Astro.props;
const categorySlug = getPostCategory(post);
const category = getCategoryBySlug(categorySlug);
const postUrl = getPostUrl(post);
const headings = extractHeadings(post.html ?? "");
const processedHtml = addHeadingIds(post.html ?? "");
const isMedical = category?.requiresMedicalReview ?? false;

const articleSchema = buildArticleSchema({
	title: post.title,
	description: post.custom_excerpt ?? post.excerpt ?? "",
	url: postUrl,
	image: post.feature_image ?? undefined,
	publishedAt: post.published_at,
	updatedAt: post.updated_at,
	authorName: post.primary_author.name,
	authorSlug: post.primary_author.slug,
	isMedical,
});

const breadcrumbSchema = buildBreadcrumbSchema([
	{ name: "Home", url: "/" },
	{ name: category?.name ?? categorySlug, url: `/${categorySlug}/` },
	{ name: post.title, url: postUrl },
]);

const seo = {
	title: post.meta_title ?? post.title,
	description: post.meta_description ?? post.custom_excerpt ?? post.excerpt ?? "",
	ogImage: post.og_image ?? post.feature_image ?? undefined,
	ogType: "article" as const,
	publishedTime: post.published_at,
	modifiedTime: post.updated_at,
	author: post.primary_author.name,
	section: category?.name,
	tags: post.tags.map((t) => t.name),
};
---

<BaseLayout seo={seo} jsonLd={[articleSchema, breadcrumbSchema]}>
	<!-- Reading progress bar -->
	<div id="reading-progress" class="reading-progress" style="width: 0%"></div>

	<article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
		<!-- Breadcrumb -->
		<nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
			<ol class="flex items-center gap-2">
				<li><a href="/" class="hover:text-teal-700 transition-colors">Home</a></li>
				<li><span>&rsaquo;</span></li>
				<li><a href={`/${categorySlug}/`} class="hover:text-teal-700 transition-colors">{category?.name ?? categorySlug}</a></li>
				<li><span>&rsaquo;</span></li>
				<li class="text-gray-400 truncate max-w-[200px]">{post.title}</li>
			</ol>
		</nav>

		<!-- Header -->
		<header class="mb-8">
			{post.primary_tag && <CategoryBadge slug={post.primary_tag.slug} size="md" />}
			<h1 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 leading-tight">
				{post.title}
			</h1>

			{(post.custom_excerpt ?? post.excerpt) && (
				<p class="mt-4 text-xl text-gray-600 leading-relaxed">
					{post.custom_excerpt ?? post.excerpt}
				</p>
			)}

			<div class="mt-6 flex flex-col sm:flex-row sm:items-center gap-4">
				<AuthorByline author={post.primary_author} />
				<div class="flex items-center gap-3 text-sm text-gray-500">
					<time datetime={post.published_at}>{formatDate(post.published_at)}</time>
					<span>&middot;</span>
					<span>{formatReadingTime(post.reading_time)}</span>
				</div>
			</div>

			<div class="mt-4">
				<ShareButtons url={postUrl} title={post.title} />
			</div>
		</header>

		<!-- Feature image -->
		{post.feature_image && (
			<figure class="mb-8 -mx-4 sm:mx-0">
				<img
					src={post.feature_image}
					alt={post.feature_image_alt ?? post.title}
					class="w-full rounded-lg sm:rounded-xl"
					loading="eager"
				/>
				{post.feature_image_caption && (
					<figcaption class="mt-2 text-sm text-gray-500 text-center px-4">{post.feature_image_caption}</figcaption>
				)}
			</figure>
		)}

		<!-- Medical review badge for patient content -->
		{isMedical && (
			<MedicalReviewBadge
				reviewerName="Dr. Medical Reviewer"
				reviewDate={post.published_at}
				credentials="MD"
			/>
		)}

		<!-- Patient content disclaimer -->
		{isMedical && <MedicalDisclaimer variant="patient" />}

		<!-- Table of Contents -->
		<TableOfContents headings={headings} />

		<!-- Article body -->
		<div class="prose prose-lg prose-healthcare max-w-none" set:html={processedHtml} />

		<!-- Post-article newsletter CTA -->
		<NewsletterSignup variant="inline" />

		<!-- HMS CTA for relevant categories -->
		{(categorySlug === "hospital-leadership" || categorySlug === "operations" || categorySlug === "technology") && (
			<HMSLeadCTA variant="banner" />
		)}

		<!-- Share buttons (bottom) -->
		<div class="mt-10 pt-6 border-t border-gray-200">
			<ShareButtons url={postUrl} title={post.title} />
		</div>

		<!-- Author bio -->
		<div class="mt-8 p-6 bg-gray-50 rounded-xl">
			<AuthorByline author={post.primary_author} showBio size="lg" />
		</div>
	</article>
</BaseLayout>

<script>
	const progressBar = document.getElementById("reading-progress");
	if (progressBar) {
		window.addEventListener("scroll", () => {
			const scrollTop = window.scrollY;
			const docHeight = document.documentElement.scrollHeight - window.innerHeight;
			const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
			progressBar.style.width = `${Math.min(progress, 100)}%`;
		}, { passive: true });
	}
</script>

---
import type { SEOMetadata } from "@healthpulse/types";
import SEOHead from "@/components/SEOHead.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import "@/styles/global.css";

interface Props {
	seo?: Partial<SEOMetadata>;
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { seo = {}, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="alternate" type="application/rss+xml" title="HealthPulse RSS" href="/rss.xml" />
		<SEOHead seo={seo} jsonLd={jsonLd} />
	</head>
	<body class="min-h-screen flex flex-col">
		<Header />
		<main id="main-content" class="flex-1">
			<slot />
		</main>
		<Footer />
	</body>
</html>

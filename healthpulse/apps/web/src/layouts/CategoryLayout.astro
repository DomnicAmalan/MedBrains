---
import type { GhostPost } from "@healthpulse/ghost-client";
import type { Category } from "@healthpulse/types";
import { buildBreadcrumbSchema } from "@/lib/seo";
import BaseLayout from "./BaseLayout.astro";
import StoryCard from "@/components/StoryCard.astro";
import NewsletterSignup from "@/components/NewsletterSignup.astro";
import HMSLeadCTA from "@/components/HMSLeadCTA.astro";

interface Props {
	category: Category;
	posts: GhostPost[];
}

const { category, posts } = Astro.props;

const seo = {
	title: category.name,
	description: category.description,
};

const breadcrumbSchema = buildBreadcrumbSchema([
	{ name: "Home", url: "/" },
	{ name: category.name, url: `/${category.slug}/` },
]);
---

<BaseLayout seo={seo} jsonLd={breadcrumbSchema}>
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
		<!-- Category header -->
		<header class="mb-10">
			<h1 class="text-3xl md:text-4xl font-bold text-gray-900">{category.name}</h1>
			<p class="mt-3 text-lg text-gray-600 max-w-3xl">{category.description}</p>

			{category.subcategories.length > 0 && (
				<div class="mt-4 flex flex-wrap gap-2">
					{category.subcategories.map((sub) => (
						<span class="px-3 py-1 text-sm bg-gray-100 text-gray-600 rounded-full">{sub}</span>
					))}
				</div>
			)}
		</header>

		<!-- Posts grid -->
		{posts.length > 0 ? (
			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
				{posts.map((post) => (
					<StoryCard post={post} />
				))}
			</div>
		) : (
			<div class="text-center py-16">
				<p class="text-gray-500 text-lg">No articles yet in this category.</p>
				<p class="mt-2 text-gray-400">Check back soon for expert healthcare insights.</p>
			</div>
		)}

		<!-- Newsletter CTA -->
		<NewsletterSignup variant="inline" />

		<!-- HMS CTA for relevant categories -->
		{(category.slug === "hospital-leadership" || category.slug === "operations" || category.slug === "technology") && (
			<HMSLeadCTA variant="banner" />
		)}
	</div>
</BaseLayout>

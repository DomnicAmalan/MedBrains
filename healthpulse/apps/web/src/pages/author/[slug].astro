---
import type { GetStaticPaths } from "astro";
import { getAuthors, getAllPosts } from "@healthpulse/ghost-client";
import { buildBreadcrumbSchema } from "@/lib/seo";
import BaseLayout from "@/layouts/BaseLayout.astro";
import StoryCard from "@/components/StoryCard.astro";

export const getStaticPaths: GetStaticPaths = async () => {
	const authors = await getAuthors();
	const { data: allPosts } = await getAllPosts(1, 100);

	return authors.map((author) => ({
		params: { slug: author.slug },
		props: {
			author,
			posts: allPosts.filter((p) => p.authors.some((a) => a.id === author.id)),
		},
	}));
};

const { author, posts } = Astro.props;

const seo = {
	title: author.name,
	description: author.bio ?? `Articles by ${author.name} on HealthPulse`,
	ogType: "profile" as const,
};

const breadcrumbSchema = buildBreadcrumbSchema([
	{ name: "Home", url: "/" },
	{ name: "Authors", url: "/" },
	{ name: author.name, url: `/author/${author.slug}/` },
]);

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: author.name,
	description: author.bio,
	url: new URL(`/author/${author.slug}/`, Astro.site).toString(),
	image: author.profile_image,
	sameAs: [author.website, author.twitter ? `https://twitter.com/${author.twitter}` : null].filter(Boolean),
};
---

<BaseLayout seo={seo} jsonLd={[breadcrumbSchema, personSchema]}>
	<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
		<!-- Author header -->
		<header class="flex flex-col sm:flex-row items-start gap-6 mb-10">
			<div class="w-20 h-20 rounded-full bg-teal-100 text-teal-700 flex items-center justify-center text-2xl font-bold flex-shrink-0">
				{author.profile_image ? (
					<img
						src={author.profile_image}
						alt={author.name}
						class="w-20 h-20 rounded-full object-cover"
					/>
				) : (
					author.name.split(" ").map((n: string) => n[0]).join("").slice(0, 2)
				)}
			</div>
			<div>
				<h1 class="text-3xl font-bold text-gray-900">{author.name}</h1>
				{author.location && (
					<p class="mt-1 text-sm text-gray-500">{author.location}</p>
				)}
				{author.bio && (
					<p class="mt-3 text-gray-600 leading-relaxed">{author.bio}</p>
				)}
				<div class="mt-3 flex gap-3">
					{author.website && (
						<a href={author.website} target="_blank" rel="noopener noreferrer" class="text-sm text-teal-700 hover:underline">
							Website
						</a>
					)}
					{author.twitter && (
						<a href={`https://twitter.com/${author.twitter}`} target="_blank" rel="noopener noreferrer" class="text-sm text-teal-700 hover:underline">
							Twitter
						</a>
					)}
				</div>
			</div>
		</header>

		<!-- Author's articles -->
		<section>
			<h2 class="text-xl font-bold text-gray-900 mb-6">
				Articles by {author.name} ({posts.length})
			</h2>
			{posts.length > 0 ? (
				<div class="grid sm:grid-cols-2 gap-6">
					{posts.map((post: any) => (
						<StoryCard post={post} />
					))}
				</div>
			) : (
				<p class="text-gray-500">No articles published yet.</p>
			)}
		</section>
	</div>
</BaseLayout>

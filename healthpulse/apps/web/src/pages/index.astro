---
import { getAllPosts } from "@healthpulse/ghost-client";
import { CATEGORIES } from "@/data/categories";
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroSection from "@/components/HeroSection.astro";
import StoryCard from "@/components/StoryCard.astro";
import QuickPostCard from "@/components/QuickPostCard.astro";
import NewsletterSignup from "@/components/NewsletterSignup.astro";
import HMSLeadCTA from "@/components/HMSLeadCTA.astro";

const { data: posts } = await getAllPosts(1, 15);
const featuredPost = posts.find((p) => p.featured) ?? posts[0];
const remainingPosts = posts.filter((p) => p.id !== featuredPost?.id);
const mainFeed = remainingPosts.slice(0, 6);
const sidebarPosts = remainingPosts.slice(6, 12);
---

<BaseLayout>
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
		<!-- Hero -->
		{featuredPost && <HeroSection post={featuredPost} />}

		<!-- Main content + sidebar -->
		<div class="grid lg:grid-cols-3 gap-10">
			<!-- Main feed -->
			<div class="lg:col-span-2">
				<h2 class="text-xl font-bold text-gray-900 mb-6">Latest Stories</h2>
				<div class="grid sm:grid-cols-2 gap-6">
					{mainFeed.map((post) => (
						<StoryCard post={post} />
					))}
				</div>

				<!-- Inline newsletter -->
				<NewsletterSignup variant="inline" />
			</div>

			<!-- Sidebar -->
			<aside class="space-y-8">
				<!-- Trending / Recent -->
				{sidebarPosts.length > 0 && (
					<div>
						<h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Trending</h3>
						{sidebarPosts.map((post) => (
							<QuickPostCard post={post} />
						))}
					</div>
				)}

				<!-- Newsletter signup -->
				<NewsletterSignup variant="sidebar" />

				<!-- Categories -->
				<div>
					<h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Explore Topics</h3>
					<div class="space-y-2">
						{CATEGORIES.map((cat) => (
							<a
								href={`/${cat.slug}/`}
								class="block px-4 py-3 bg-white border border-gray-100 rounded-lg hover:border-teal-300 hover:bg-teal-50 transition-colors"
							>
								<span class="font-medium text-sm text-gray-900">{cat.name}</span>
								<p class="mt-0.5 text-xs text-gray-500 line-clamp-1">{cat.description}</p>
							</a>
						))}
					</div>
				</div>

				<!-- HMS CTA -->
				<HMSLeadCTA variant="sidebar" />
			</aside>
		</div>
	</div>
</BaseLayout>

---
import type { GetStaticPaths } from "astro";
import { getTags, getPostsByTag } from "@healthpulse/ghost-client";
import BaseLayout from "@/layouts/BaseLayout.astro";
import StoryCard from "@/components/StoryCard.astro";

export const getStaticPaths: GetStaticPaths = async () => {
	const tags = await getTags();
	const paths = [];

	for (const tag of tags) {
		const { data: posts } = await getPostsByTag(tag.slug);
		paths.push({
			params: { slug: tag.slug },
			props: { tag, posts },
		});
	}

	return paths;
};

const { tag, posts } = Astro.props;
---

<BaseLayout seo={{ title: tag.name, description: tag.description ?? `Articles tagged ${tag.name}` }}>
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
		<header class="mb-10">
			<p class="text-sm text-gray-500 uppercase tracking-wider mb-2">Tag</p>
			<h1 class="text-3xl font-bold text-gray-900">{tag.name}</h1>
			{tag.description && (
				<p class="mt-3 text-lg text-gray-600">{tag.description}</p>
			)}
		</header>

		{posts.length > 0 ? (
			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
				{posts.map((post: any) => (
					<StoryCard post={post} />
				))}
			</div>
		) : (
			<p class="text-gray-500 text-lg text-center py-16">No articles with this tag yet.</p>
		)}
	</div>
</BaseLayout>

# PostgreSQL
DATABASE_URL=postgres://medbrains:medbrains_dev@localhost:5435/medbrains
DB_POOL_MAX_CONNECTIONS=20
DB_POOL_MIN_CONNECTIONS=2
DB_POOL_ACQUIRE_TIMEOUT_SECS=5
DB_POOL_IDLE_TIMEOUT_SECS=600
DB_POOL_MAX_LIFETIME_SECS=1800
DB_STATEMENT_CACHE_CAPACITY=256
DB_SLOW_QUERY_MS=250

# YottaDB REST API (optional in Phase 1)
# YOTTADB_URL=http://localhost:9080

# Server
HOST=0.0.0.0
PORT=3000

# JWT (Ed25519 keys — leave unset for auto-generated dev keypair)
# JWT_PRIVATE_KEY=<base64-encoded-ed25519-private-key>
# JWT_PUBLIC_KEY=<base64-encoded-ed25519-public-key>

# CORS & Cookies
CORS_ORIGIN=http://localhost:5173
# COOKIE_DOMAIN=
SECURE_COOKIES=false

# Logging
RUST_LOG=medbrains_server=debug,tower_http=debug

# ──────────────────────────────────────────────────────────────────
# ReBAC — SpiceDB sidecar (optional; falls back to PgAuthzBackend)
# ──────────────────────────────────────────────────────────────────
SPICEDB_ENDPOINT=http://localhost:50051
SPICEDB_TOKEN=devsecret

# ──────────────────────────────────────────────────────────────────
# SMS — Twilio (production) or stub (dev) when unset
# ──────────────────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+91XXXXXXXXXX
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # India DLT routing (optional)
# DLT_ENFORCE=true                                                # India: refuse to send if no registered template matches event scope

# ──────────────────────────────────────────────────────────────────
# Email — SendGrid (production) or stub (dev) when unset
# ──────────────────────────────────────────────────────────────────
# EMAIL_PROVIDER=sendgrid                                          # or "ses" (pending SigV4)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM_ADDRESS=hospital@example.com
# EMAIL_FROM_NAME=MedBrains Hospital

# ──────────────────────────────────────────────────────────────────
# WhatsApp — Meta Cloud API
# ──────────────────────────────────────────────────────────────────
# WHATSAPP_PHONE_NUMBER_ID=000000000000000
# WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────────
# NHCX (insurance claims gateway, India)
# ──────────────────────────────────────────────────────────────────
# NHCX_BASE_URL=https://apisbx.abdm.gov.in/hcx/v1                  # sandbox
# NHCX_PARTICIPANT_CODE=hospital@nhcx
# NHCX_PRIVATE_KEY_PEM=                                            # multi-line PEM ok with quotes
# NHCX_BEARER_TOKEN=                                               # short-lived from /sessions
# NHCX_RECIPIENT_PUBLIC_KEY=                                       # default payer; per-payer keys via :{code} suffix
# NHCX_SENDER_PUBLIC_KEY:starhealth=                               # one per payer (callback verify)

# ──────────────────────────────────────────────────────────────────
# ABDM (Ayushman Bharat Digital Mission)
# ──────────────────────────────────────────────────────────────────
# ABDM_BASE_URL=https://abhasbx.abdm.gov.in
# ABDM_HIE_GATEWAY_URL=https://dev.abdm.gov.in/gateway/v0.5
# ABDM_BEARER_TOKEN=
# ABDM_HIP_ID=medbrains.hip

# Notes
# • All credentials are read at request time via the EnvSecretResolver,
#   so rotation = update .env + restart. No per-tenant DB vault needed.
# • Missing credentials → handlers return Ok({stub:true,reason:"creds_unset"})
#   for graceful dev/CI behaviour. Production deploys must set all
#   integrations they actually use.
# • Multi-tenant prod: prefer FileSecretResolver pointing at /etc/medbrains/secrets/
#   or wire a Vault/KMS-backed resolver in main.rs.

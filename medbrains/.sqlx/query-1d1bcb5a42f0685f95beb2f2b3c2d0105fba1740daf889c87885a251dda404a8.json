  "query": "SELECT p.id, p.uhid, p.first_name, p.last_name, p.date_of_birth, p.phone, p.gender, 1.0::float8 AS score FROM patients p JOIN patient_identifiers pi ON pi.patient_id = p.id AND pi.tenant_id = p.tenant_id WHERE p.tenant_id = $1 AND pi.id_number_hash = $2 AND p.is_merged = false AND p.is_active = true LIMIT 10",

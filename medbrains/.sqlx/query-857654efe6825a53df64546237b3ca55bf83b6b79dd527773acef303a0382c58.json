{
  "db_name": "PostgreSQL",
  "query": "SELECT\n            i.id,\n            i.invoice_number,\n            i.status,\n            i.total_amount,\n            i.paid_amount,\n            (i.total_amount - i.paid_amount) AS balance,\n            (SELECT COUNT(*) FROM invoice_items ii WHERE ii.invoice_id = i.id) AS item_count,\n            i.issued_at,\n            i.created_at\n         FROM invoices i\n         WHERE i.patient_id = $1\n         ORDER BY i.created_at DESC",

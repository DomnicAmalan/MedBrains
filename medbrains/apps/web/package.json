{
  "name": "@medbrains/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "typecheck": "tsc --noEmit",
    "analyze": "ANALYZE=true vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:mock": "playwright test --project mock-chromium e2e/mock/",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@mantine/charts": "^9.0.1",
    "@mantine/core": "^9.0.1",
    "@mantine/dates": "^9.0.1",
    "@mantine/hooks": "^9.0.1",
    "@mantine/notifications": "^9.0.1",
    "@mantine/schedule": "^9.0.0",
    "@mantine/spotlight": "^9.0.1",
    "@medbrains/api": "workspace:*",
    "@medbrains/crdt": "workspace:*",
    "@medbrains/expressions": "workspace:*",
    "@medbrains/schemas": "workspace:*",
    "@medbrains/stores": "workspace:*",
    "@medbrains/types": "workspace:*",
    "@medbrains/utils": "workspace:*",
    "@tabler/icons-react": "^3.40.0",
    "@tanstack/react-query": "^5.90.21",
    "@xyflow/react": "^12.10.1",
    "codemirror": "^6.0.2",
    "dayjs": "^1.11.20",
    "healthicons-react": "^3.5.0",
    "i18next": "^25.10.3",
    "i18next-http-backend": "^3.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.6.0",
    "react-router": "^7.13.1",
    "react-use": "^17.6.0",
    "recharts": "^3.8.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "rollup-plugin-visualizer": "^7.0.1",

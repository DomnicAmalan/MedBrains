# MedBrains Server Configuration
#
# Copy this file to `config.toml` and adjust values as needed.
# Layer order: compiled defaults → config.toml → environment variables.
# Environment variables always take highest priority.

# PostgreSQL connection string (required — no default)
# database_url = "postgres://medbrains:medbrains_dev@localhost:5435/medbrains"

# YottaDB REST API (optional — Phase 2)
# yottadb_url = "http://localhost:9080"

# Server bind address
host = "0.0.0.0"
port = 3000

# JWT Ed25519 keys (base64-encoded)
# Leave unset to auto-generate an ephemeral dev keypair on startup.
# jwt_private_key = "<base64-encoded-ed25519-private-key>"
# jwt_public_key = "<base64-encoded-ed25519-public-key>"

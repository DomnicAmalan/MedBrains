# MedBrains standalone production env — copy to /etc/medbrains/env on
# the target server and chmod 600. Keys are pulled from this file by
# both medbrains-server.service and medbrains-archive.service.

# ── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgres://medbrains:CHANGEME@127.0.0.1:5432/medbrains
DB_POOL_MAX_CONNECTIONS=20
DB_POOL_MIN_CONNECTIONS=2

# ── HTTP server ─────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=3000

# ── Static SPA frontend ─────────────────────────────────────────────
# install.sh copies the built `apps/web/dist/` here.
STATIC_DIR=/var/www/medbrains

# ── JWT (Ed25519) ───────────────────────────────────────────────────
# Generate once on the server:
#   openssl genpkey -algorithm Ed25519 | base64 -w0   → JWT_PRIVATE_KEY
#   openssl pkey -pubout -in priv.pem | base64 -w0    → JWT_PUBLIC_KEY
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── CORS / cookies (production hardening) ───────────────────────────
CORS_ORIGIN=https://hims.alagappahospital.com
COOKIE_DOMAIN=hims.alagappahospital.com
SECURE_COOKIES=true

# Caddy is the trusted proxy on the same host — accept X-Forwarded-For
# from loopback only so external clients can't spoof IPs.
TRUSTED_PROXIES=127.0.0.1/32,::1/128

# ── Logging ─────────────────────────────────────────────────────────
RUST_LOG=medbrains_server=info,tower_http=warn

# ── Object-storage tier roots (medbrains-archive sweeper) ──────────
# install.sh creates these dirs with appropriate ownership.
MEDBRAINS_OBJECTS_HOT=/var/lib/medbrains/objects
MEDBRAINS_OBJECTS_COLD=/var/lib/medbrains/cold
MEDBRAINS_OBJECTS_ARCHIVE=/var/lib/medbrains/archive

# ── Optional integrations (leave unset for pilot) ──────────────────
# SMS / Email / WhatsApp / NHCX / ABDM / SpiceDB. The server falls
# back to internal stubs when these are unset, which is fine for
# the pilot but should be filled in before real patient traffic.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# SENDGRID_API_KEY=
# SPICEDB_ENDPOINT=
# SPICEDB_TOKEN=

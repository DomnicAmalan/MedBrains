{
  "expo": {
    "name": "{{displayName}}",
    "slug": "{{id}}",
    "version": "0.1.0",
    "orientation": {{#if isTv}}"landscape"{{else}}"portrait"{{/if}},
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "bundleIdentifier": "{{bundleId}}",
      "supportsTablet": {{#if isTv}}true{{else}}false{{/if}},
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan device-pairing QR codes.",
        "NSFaceIDUsageDescription": "Used to unlock the app with Face ID."
      }
    },
    "android": {
      "package": "{{bundleId}}",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1F4332"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Used to scan device-pairing QR codes."
        }
      ]{{#if offlineFirst}},
      [
        "@medbrains/uniffi-rn-plugin",
        {
          "cratePath": "../../crates/medbrains-edge-rn",
          "udlPath": "../../crates/medbrains-edge-rn/src/edge_rn.udl",
          "iosTargets": ["aarch64-apple-ios", "aarch64-apple-ios-sim"],
          "androidAbis": ["arm64-v8a", "armeabi-v7a", "x86_64"]
        }
      ]{{/if}}{{#if isTv}},
      [
        "@react-native-tvos/config-tv",
        {
          "showVerboseWarnings": false,
          "androidTVBanner": "./assets/tv-banner.png"
        }
      ]{{/if}}
    ]
  }
}
